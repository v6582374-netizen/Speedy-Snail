{
  "manifest_version": 3,
  "name": "Speedy Snail",
  "version": "0.1.0",
  "description": "Hold ArrowRight on supported video sites to fast-forward; YouTube can also stay at the best display-matched quality.",
  "permissions": ["storage", "system.display"],
  "action": {
    "default_title": "Speedy Snail",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://pan.baidu.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://masterclass.com/*", "https://*.masterclass.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/page-quality.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
